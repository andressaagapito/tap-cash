# =============================================================================
# TapCash — variáveis de ambiente do frontend (Vite)
# Copie para .env.local em desenvolvimento.
# =============================================================================

# --- Desenvolvimento local ---
# Deixe vazio: o Vite usa proxy /api → backend em http://127.0.0.1:8000
# VITE_API_URL=

# --- Produção (Vercel) ---
# URL pública da API no Render, sem barra no final:
# VITE_API_URL=https://tapcash-api.onrender.com
